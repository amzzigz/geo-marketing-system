# GEO营销系统 - 开发环境配置模板
# 复制为 .env 使用

# 数据库连接（SQL Server Windows认证）
DATABASE_URL=mssql+aioodbc:///?odbc_connect=DRIVER={ODBC Driver 17 for SQL Server};SERVER=localhost;DATABASE=geo_marketing;Trusted_Connection=yes

# JWT配置
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# One API配置
ONE_API_BASE_URL=http://localhost:3000
ONE_API_KEY=sk-your-one-api-key-here

# 文件上传目录
UPLOAD_DIR=./uploads
